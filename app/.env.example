# =============================================================================
# AdRide (Next.js web) — zmienne środowiskowe
# Skopiuj do .env.local i uzupełnij. NIGDY nie commituj .env.local.
# =============================================================================

# ─── Supabase (PUBLIC — trafiają do przeglądarki) ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# ─── Supabase (SECRET — tylko serwer/API routes) ─────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=sbp_xxx

# ─── Stripe (PUBLIC) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# ─── Stripe (SECRET — tylko serwer) ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── App ─────────────────────────────────────────────────────────────────────
# Produkcja: https://app.adride.pl ; lokalnie: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Mapbox (mapa kampanii) ──────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1xxx

# ─── Port aplikacji w produkcji (PM2/Nginx → 3001) ───────────────────────────
PORT=3001
